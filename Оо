

python
# Вводим количество кустов
n = int(input())

# Вводим урожайность каждого куста
berries = []
for i in range(n):
    a = int(input())
    berries.append(a)

# Если кустов мало, считаем отдельно
if n == 1:
    print(berries[0])
elif n == 2:
    print(berries[0] + berries[1])
else:
    # Ищем максимальную сумму трёх соседних кустов
    max_sum = 0
    
    for i in range(n):
        # Левый сосед (с учётом круга)
        left = i - 1
        if left < 0:
            left = n - 1
        
        # Правый сосед (с учётом круга)
        right = i + 1
        if right >= n:
            right = 0
        
        # Сумма текущего куста и двух соседей
        s = berries[left] + berries[i] + berries[right]
        
        # Запоминаем максимум
        if s > max_sum:
            max_sum = s
    
print(max_sum)


